# Front-end variables for Vercel (publicly exposed to the browser)
NEXT_PUBLIC_CONTROL_API_URL=https://api.example.com
NEXT_PUBLIC_TELEMETRY_WS_URL=wss://api.example.com/telemetry
NEXT_PUBLIC_APP_TITLE=Polymarket Control Room
NEXT_PUBLIC_ENVIRONMENT=production

# Backend / VPS variables
NODE_ENV=production
API_PORT=3000

# PostgreSQL in Docker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=polymarket
POSTGRES_HOST=postgres
DATABASE_URL=postgresql://postgres:change_me_strong_password@postgres:5432/polymarket?schema=public

# Redis in Docker
REDIS_PASSWORD=change_me_strong_password
REDIS_URL=redis://:change_me_strong_password@redis:6379

# Blockchain and Polymarket access
POLYGON_RPC_URLS=https://polygon-mainnet.g.alchemy.com/v2/yourkey,https://polygon-rpc.com
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
POLYMARKET_API_KEY=your_polymarket_api_key

# Optional proxy/residential proxy configuration for external API calls
PROXY_URL=http://user:password@proxy-host:port
PROXY_TYPE=http
PROXY_SOCKS_URL=socks5://user:password@proxy-host:port

# Security credentials
JWT_SECRET=your_jwt_secret_here
TOTP_SECRET=your_totp_secret_here

# Bot risk & execution settings
SIMULATION_MODE=false
MARKET_DATA_STALE_THRESHOLD_MS=2000
MAX_SLIPPAGE_PCT=0.6
MAX_POSITION_USD=25000
MAX_MARKET_POSITION_USD=10000
MAX_ORDER_USD=5000
MIN_STRATEGY_EDGE_PCT=0.002
MAX_DAILY_LOSS_USD=10000
MAX_SINGLE_LOSS_USD=2500
CIRCUIT_BREAKER_LOSS_WINDOW_MS=86400000
CIRCUIT_BREAKER_COOLDOWN_MS=3600000
ORDER_TIMEOUT_MS=180000

# IMPORTANT: Ne pas committer de véritables secrets. Copiez ce fichier en .env sur le serveur VPS et stockez les valeurs réelles en dehors du code source.

