# ─── Polygon RPC ─────────────────────────────────────────────────────────────
POLYGON_RPC_HTTP=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_WS=wss://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_FALLBACK_1=https://polygon-rpc.com
POLYGON_RPC_FALLBACK_2=https://rpc-mainnet.maticvigil.com
POLYGON_CHAIN_ID=137

# ─── Wallet ───────────────────────────────────────────────────────────────────
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS

# ─── Proxy (dev local depuis France — laisser vide sur VPS Hetzner) ──────────
# Format HTTP :   HTTPS_PROXY=http://user:pass@host:port
# Format SOCKS5 : HTTPS_PROXY=socks5://host:port
# Tunnel SSH :    HTTPS_PROXY=socks5://127.0.0.1:1080  (voir ci-dessous)
HTTPS_PROXY=

# ─── Polymarket CLOB API ─────────────────────────────────────────────────────
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ─── Smart Contracts (Polygon Mainnet) ───────────────────────────────────────
CTF_CONTRACT_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
CTF_EXCHANGE_ADDRESS=0x4bFb41d5B3570DeFd03C39a9A4D8dE6Bd8B8982E
USDC_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
NEG_RISK_ADAPTER_ADDRESS=0xd91E80cF2E7be2e162c6513ceD06f1dD0dA35296

# ─── AI APIs ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-YOUR_KEY
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-YOUR_KEY
ANTHROPIC_MODEL=claude-sonnet-4-6

# Grok (xAI) — OpenAI-compatible endpoint
GROK_API_KEY=xai-YOUR_KEY
GROK_MODEL=grok-3

# Google Gemini
GOOGLE_API_KEY=YOUR_GOOGLE_AI_KEY
GOOGLE_MODEL=gemini-2.0-flash

# Active provider: ANTHROPIC | OPENAI | GROK | GOOGLE
AI_PROVIDER=ANTHROPIC
AI_CONFIDENCE_THRESHOLD=0.90

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/polymarket_bot

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Backend WebSocket Server ─────────────────────────────────────────────────
WS_PORT=8080
API_PORT=3001
API_SECRET=CHANGE_ME_TO_A_STRONG_SECRET

# ─── Gas Configuration ────────────────────────────────────────────────────────
GAS_STRATEGY=FAST
GAS_LIMIT_DEFAULT=500000
MAX_FEE_GWEI_STANDARD=100
MAX_FEE_GWEI_FAST=200
MAX_FEE_GWEI_FRONTRUN=400
PRIORITY_FEE_GWEI=30

# ─── Bot Global Settings ─────────────────────────────────────────────────────
DRY_RUN=true
MAX_GLOBAL_CAPITAL_USD=10000
MAX_SLIPPAGE_PCT=2
LOG_LEVEL=info
